# Tell GitHub Linguist how to classify files correctly.

# The Wazuh agent config snippets are config, not Vim snippets.
# Mark them as documentation so they don't skew the language stats.
config-reference/* linguist-documentation

# XML decoder/rules are detection content, not "vendored" code — keep them
# counted, and ensure they're detected as XML.
detections/**/*.xml linguist-language=XML

# Netplan example is YAML config, not code.
config-reference/*.yaml linguist-language=YAML linguist-documentation
